# PostgreSQL (Staging)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crm_staging
POSTGRES_USER=staging_user
POSTGRES_PASSWORD=staging_password

# MySQL (Production)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=crm_production
MYSQL_USER=prod_user
MYSQL_PASSWORD=prod_password

# Remote Server
REMOTE_HOST=your-docker-server.com
REMOTE_USER=username
SSH_KEY_PATH=~/.ssh/id_rsa

# Pipeline Settings
DBT_TARGET=staging
LOG_LEVEL=INFO